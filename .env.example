# --- PostgreSQL (conteneur) ---
POSTGRES_USER=transpo
POSTGRES_PASSWORD=transpo_dev
POSTGRES_DB=transpo
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://transpo:transpo_dev@postgres:5432/transpo

# --- API ---
API_PORT=3000
# Secret de signature JWT — À REMPLACER en prod, ne jamais committer un vrai secret
JWT_SECRET=change-me-in-prod

# --- Divers ---
NODE_ENV=development
