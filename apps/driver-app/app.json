{
  "expo": {
    "name": "Transpo Livreur",
    "slug": "transpo-driver",
    "scheme": "transpo-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#3E63DD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anissrelicum.transpodriver"
    },
    "android": {
      "package": "com.anissrelicum.transpodriver",
      "adaptiveIcon": {
        "backgroundColor": "#3E63DD"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "apiUrl": "http://localhost:3000",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0762a0f7-aae8-47f1-9014-e8bc02cde3f0"
      }
    },
    "owner": "anissrelicum"
  }
}
